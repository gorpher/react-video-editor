TZ=Asia/Shanghai

# postgres
POSTGRES_DB=openvideo_editor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# web
WEB_PORT=5000
BETTER_AUTH_URL=http://localhost:5000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# aifilm integration (external service via HTTP, independent deployment)
# example:
# - same host (Docker Desktop): http://host.docker.internal:3000
# - remote host: http://192.168.x.x:3000
AIFILM_API_BASE_URL=
AIFILM_DEV_USER_ID=

# deepgram
DEEPGRAM_URL=https://api.deepgram.com/v1
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_URL=https://api.elevenlabs.io
ELEVENLABS_MODEL=eleven_multilingual_v2

# pexels
PEXELS_API_KEY=

# object storage
R2_PUBLIC_DOMAIN=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=

# auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# email
RESEND_API_KEY=
